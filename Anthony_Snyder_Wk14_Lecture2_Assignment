#Unit 3 Advanced Exercise
table = [[i * j for j in range(1,5)] for i in range(1,5)]
print("Multiplication Table: ")
for row in table:
    for value in row:
        print(f"{value:3}", end=" ")
    print()
def sum_diagonal(matrix):
    sum = 0
    for i in range(len(matrix)):
        sum += matrix[i][i]
    return sum
diag_sum = sum_diagonal(table)
print("\nDiagonal Sum: ", diag_sum)
even_numbers = (num for row in table for num in row if num % 2 == 0)
print("\nFirst 5 even numbers: ")
for _, value in zip(range(5), even_numbers):
    print(value)