#Unit 2 Advanced Exercise
def calculate_statistics(*args):
    count = len(args)
    total = sum(args)
    average = (f"{total / count if count > 0 else 0:.2f}")
    return (count, total, average)
def update_student_records(students, bonus):
    updated = []
    for name, grade in students:
        new_grade = grade + bonus
        updated.append((name, new_grade))
    return updated
students = [("Alice", 78), ("Bob", 85), ("Charlie", 90)]
updated_students = update_student_records(students, 5)
updated_grades = [grade for name, grade in updated_students]
stats = calculate_statistics(*updated_grades)
print("Original students: ", students)
print("Updated students: ", updated_students)
print("Statistics (count, sum, average): ", stats)

